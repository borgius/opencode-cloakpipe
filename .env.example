# Copy to .env for local development. Never commit real values.

# CloakPipe direct privacy API. The default sidecar listens on localhost.
OPENCODE_CLOAKPIPE_BASE_URL=http://127.0.0.1:3100/v1

# Strict mode fails provider-bound hooks when CloakPipe is unavailable.
OPENCODE_CLOAKPIPE_STRICT=1

# Optional diagnostics. Logs counts and status only, never raw prompt/tool text.
OPENCODE_CLOAKPIPE_DEBUG=0

# Request timeout values in milliseconds.
OPENCODE_CLOAKPIPE_TIMEOUT_MS=30000
OPENCODE_CLOAKPIPE_HEALTH_TIMEOUT_MS=3000

# Feature flags.
OPENCODE_CLOAKPIPE_TRANSFORM_SYSTEM=1
OPENCODE_CLOAKPIPE_RESTORE_ASSISTANT_TEXT=1
OPENCODE_CLOAKPIPE_RESTORE_TOOL_ARGS=1
OPENCODE_CLOAKPIPE_TRANSFORM_TOOL_DEFINITIONS=0
